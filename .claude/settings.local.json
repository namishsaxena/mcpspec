{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:ts.sdk.modelcontextprotocol.io)",
      "Bash(gh api:*)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:modelcontextprotocol.github.io)",
      "WebFetch(domain:py.sdk.modelcontextprotocol.io)",
      "WebFetch(domain:registry.npmjs.org)",
      "WebFetch(domain:pypi.org)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm vitest:*)",
      "Bash(node -e \"import\\(''@modelcontextprotocol/sdk/server/auth/provider.js''\\).then\\(m => console.log\\(Object.keys\\(m\\)\\)\\)\")",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm:*)",
      "WebFetch(domain:docs.astral.sh)",
      "Bash(uv:*)",
      "Bash(uv run:*)",
      "Bash(python3 -c \"import json; json.load\\(open\\(''.claude/settings.local.json''\\)\\)\")"
    ],
    "deny": [
      "Edit(file_path:.env)",
      "Write(file_path:.env)",
      "Edit(file_path:secrets/*)",
      "Write(file_path:secrets/*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "github"
  ],
  "disabledMcpjsonServers": [
    "github"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/warn-large-files.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-dangerous-commands.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/protect-files.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/scan-secrets.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
